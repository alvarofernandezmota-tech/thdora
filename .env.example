# ============================================================
# THDORA — Variables de entorno
# Copiar a .env y rellenar con valores reales:
#   cp .env.example .env
# NUNCA commitear el .env real (está en .gitignore)
# ============================================================

# ── Bot Telegram ─────────────────────────────────────────
TELEGRAM_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Usuario(s) permitidos (Telegram user_id, separados por coma)
# Obtener tu ID: envia /start a @userinfobot
ALLOWED_USER_ID=123456789

# ── API interna ─────────────────────────────────────────
# En Docker: http://thdora:8000 (nombre del servicio en docker-compose)
# En local:  http://localhost:8000
THDORA_API_URL=http://thdora:8000

# Clave secreta para firma de tokens internos (mínimo 32 caracteres)
SECRET_KEY=cambia_esto_por_una_clave_secreta_de_al_menos_32_chars

# ── Base de datos ────────────────────────────────────────
# SQLite (desarrollo / Servidor Madre actual)
DATABASE_URL=sqlite:///./data/thdora.db

# PostgreSQL (produccion futura - descomentar cuando se migre)
# DATABASE_URL=postgresql://thdora:password@localhost:5432/thdora

# ── LLM ─────────────────────────────────────────────────
# API key de Groq (NLP del bot)
# Obtener en: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo Groq a usar
GROQ_MODEL=llama-3.1-8b-instant

# ── Integración GitHub (handler /diario - roadmap v0.18) ──────
# Token de GitHub con permisos: contents:write en yggdrasil-dew
# Obtener en: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=alvarofernandezmota-tech/yggdrasil-dew

# ── Logs ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Scheduler ──────────────────────────────────────────────
# Timezone para el scheduler de notificaciones
TZ=Europe/Madrid
