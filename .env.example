# ================================================
# THDORA — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ================================================

# ── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_token_real_aqui
ALLOWED_USERS=tu_telegram_id_numerico
OWNER_TELEGRAM_ID=tu_telegram_id_numerico

# ── Groq LLM ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_tu_clave_groq_aqui
GROQ_MODEL=llama-3.3-70b-versatile
LLM_BACKEND=groq

# ── GitHub (opcional) ──────────────────────────────────────────
GITHUB_TOKEN=

# ── API interna ───────────────────────────────────────────────
THDORA_API_URL=http://thdora:8000

# ── Base de datos ────────────────────────────────────────────
THDORA_DB_PATH=/app/data/thdora.db
THDORA_DB_URL=sqlite:////app/data/thdora.db

# ── Logs ────────────────────────────────────────────────────
LOG_LEVEL=INFO
