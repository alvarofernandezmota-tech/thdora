# ── Base de datos ─────────────────────────────
DATABASE_URL=sqlite:///./thdora.db

# ── Telegram ──────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── LLM Backend ───────────────────────────────
LLM_BACKEND=groq               # groq | ollama
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# ── Beta cerrada ──────────────────────────────
ALLOWED_USERS=                 # CSV de Telegram IDs (ej: 123456,789012)
OWNER_TELEGRAM_ID=             # siempre tiene acceso

# ── Deploy ────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
