# ──────────────────────────────────────────────────────────────────────────
# THDORA — Variables de entorno para Docker
# Copia este fichero a .env en la raíz del proyecto:
#   cp docker/.env.docker.example .env
# NO versiones .env — está en .gitignore
# ──────────────────────────────────────────────────────────────────────────

# ─ OBLIGATORIO ───────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=tu_token_aqui

# ─ RUTAS INTERNAS (no cambiar salvo que muevas el volumen) ────────────────
THDORA_API_URL=http://api:8000
THDORA_DB_PATH=/app/data/thdora.db

# ─ OPCIONAL ──────────────────────────────────────────────────────────────
# LOG_LEVEL=info
# TZ=Europe/Madrid
