# ─────────────────────────────────────────────────────────────
# THDORA — variables de entorno para Docker
# PRIMER PASO: cp docker/.env.docker.example .env
# Luego edita .env con tus credenciales reales
# NUNCA subas .env al repo
# ─────────────────────────────────────────────────────────────

# ── Telegram (OBLIGATORIO) ──────────────────────────────────
TELEGRAM_BOT_TOKEN=changeme

# ── Groq LLM (OBLIGATORIO) ──────────────────────────────────
GROQ_API_KEY=changeme
GROQ_MODEL=llama-3.3-70b-versatile
LLM_BACKEND=groq

# ── Base de datos ──────────────────────────────────────────
THDORA_DB_URL=sqlite:////app/data/thdora.db

# ── Control de acceso ──────────────────────────────────────
OWNER_TELEGRAM_ID=0
ALLOWED_USERS=

# ── API interna ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
THDORA_API_URL=http://thdora:8000

# ── GitHub (OPCIONAL — solo para /diario) ──────────────────
GITHUB_TOKEN=
GITHUB_OWNER=alvarofernandezmota-tech
GITHUB_REPO=yggdrasil-dew

# ── OpenWeatherMap (OPCIONAL — solo para /tiempo) ──────────
OWM_API_KEY=

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Admin ────────────────────────────────────────────────────
ADMIN_TOKEN=
